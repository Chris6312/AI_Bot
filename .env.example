# Tradier Brokerage - legacy fallback (still supported)
TRADIER_API_KEY=
TRADIER_ACCOUNT_ID=
TRADIER_BASE_URL=https://sandbox.tradier.com/v1

# Tradier Paper Account (recommended)
TRADIER_PAPER_API_KEY=
TRADIER_PAPER_ACCOUNT_ID=
TRADIER_PAPER_BASE_URL=https://sandbox.tradier.com/v1

# Tradier Live Account
TRADIER_LIVE_API_KEY=
TRADIER_LIVE_ACCOUNT_ID=
TRADIER_LIVE_BASE_URL=https://api.tradier.com/v1

# Kraken CLI / future live mode
KRAKEN_CLI_PATH=kraken
KRAKEN_API_KEY=
KRAKEN_API_SECRET=

# Discord
DISCORD_BOT_TOKEN=
DISCORD_TRADING_CHANNEL_ID=0
DISCORD_USER_ID=0
DISCORD_ALLOWED_ROLE_IDS=
DISCORD_DECISION_MAX_AGE_SECONDS=900
DISCORD_REQUIRE_DECISION_TIMESTAMP=true

# Control Plane
# Control plane must be ARMED before any execution path can submit orders
ADMIN_API_TOKEN=

# Database
DATABASE_URL=postgresql://bot_user:changeme@postgres:5432/trading_bot
REDIS_URL=redis://redis:6379

# App Settings
APP_ENV=development
SECRET_KEY=change-this-to-a-random-32-character-string
LOG_LEVEL=INFO
BOT_DEFAULT_STOCK_MODE=PAPER
BOT_DEFAULT_CRYPTO_MODE=PAPER
RUNTIME_STATE_FILE=./backend/.runtime/runtime_state.json
BACKUP_ROOT_DIR=./backups

# Safety Limits
SAFETY_MAX_TRADES_PER_DAY=3
SAFETY_MAX_POSITION_SIZE_PCT=0.25
SAFETY_MAX_DAILY_LOSS=500.00
SAFETY_VIX_MAX=35.0
SAFETY_GRACE_PERIOD_SECONDS=30
SAFETY_ALLOW_OVERRIDE=false
SAFETY_REQUIRE_MARKET_HOURS=true
ORDER_FILL_CONFIRM_RETRIES=3
ORDER_FILL_CONFIRM_DELAY_SECONDS=1.0
PRE_TRADE_STOCK_QUOTE_MAX_AGE_SECONDS=30
PRE_TRADE_CRYPTO_TICKER_MAX_AGE_SECONDS=30
PRE_TRADE_CRYPTO_MAX_CANDLE_GAP_FACTOR=2.5

# Risk Management
STOP_LOSS_PCT=0.015
PROFIT_TARGET_PCT=0.025
TRAILING_STOP_PCT=0.03
TIME_STOP_HOUR=15
TIME_STOP_MINUTE=45

# ============================================
# GLOBAL POSITION SIZING SETTINGS
# ============================================

# Position size as percentage of available balance
POSITION_SIZE_PCT=0.10              # 10% per position (stocks & crypto)

# Alternative: Fixed dollar amount per position
# POSITION_SIZE_FIXED=10000         # Uncomment to use fixed $10k per position

# Maximum positions per decision
MAX_POSITIONS_PER_DECISION=3        # Max 3 trades in one screening

# Minimum position size (safety check)
MIN_POSITION_USD=1000               # Don't execute positions < $1,000

# Maximum position size (safety check)
MAX_POSITION_PCT=0.25               # No single position > 25% of equity

# ============================================
# ASSET-SPECIFIC OVERRIDES (Optional)
# ============================================

# Stock-specific (overrides global if set)
# STOCK_POSITION_SIZE_PCT=0.15      # 15% for stocks only
# STOCK_MIN_POSITION_USD=2000       # Min $2k for stocks

# Crypto-specific (overrides global if set)
# CRYPTO_POSITION_SIZE_PCT=0.08     # 8% for crypto only
# CRYPTO_MIN_POSITION_USD=500       # Min $500 for crypto
