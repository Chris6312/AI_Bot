# Tradier Brokerage
TRADIER_API_KEY=your_tradier_api_key_here
TRADIER_ACCOUNT_ID=your_account_id_here
TRADIER_BASE_URL=https://sandbox.tradier.com/v1

# Discord
DISCORD_BOT_TOKEN=your_bot_token_here
DISCORD_TRADING_CHANNEL_ID=1234567890123456789
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/123456789/abc...
DISCORD_USER_ID=your_discord_user_id

# Database
DATABASE_URL=postgresql://bot_user:changeme@postgres:5432/trading_bot
REDIS_URL=redis://redis:6379

# App Settings
APP_ENV=development
SECRET_KEY=change-this-to-a-random-32-character-string
LOG_LEVEL=INFO

# Safety Limits
SAFETY_MAX_TRADES_PER_DAY=3
SAFETY_MAX_POSITION_SIZE_PCT=0.25
SAFETY_MAX_DAILY_LOSS=500.00
SAFETY_VIX_MAX=35.0
SAFETY_GRACE_PERIOD_SECONDS=30
SAFETY_ALLOW_OVERRIDE=true

# Risk Management
STOP_LOSS_PCT=0.015
PROFIT_TARGET_PCT=0.025
TRAILING_STOP_PCT=0.03
TIME_STOP_HOUR=15
TIME_STOP_MINUTE=45
